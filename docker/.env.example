# Copy to .env and set your API keys before running docker compose up

# Admin API key — used by the backend for provisioning and as the JWT signing secret
# Generate with: openssl rand -hex 32
QDRANT_API_KEY=replace-with-openssl-rand-hex-32

# Read-only API key — optional
# Generate with: openssl rand -hex 32
QDRANT_READ_ONLY_API_KEY=replace-with-openssl-rand-hex-32
